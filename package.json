{
  "name": "blockchain-evoting",
  "version": "1.0.0",
  "description": "Blockchain-based e-voting prototype with Groth16 proofs, homomorphic tallying, and receipt-based Merkle auditability.",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "node": "hardhat node",
    "server": "python -m uvicorn server:app --port 8000"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.4"
  },
  "dependencies": {
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "dotenv": "^16.3.1",
    "snarkjs": "^0.7.3"
  }
}
